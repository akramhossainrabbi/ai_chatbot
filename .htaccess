PassengerEnabled on
PassengerAppRoot /home/yourusername/ai_chatbot
PassengerBaseURI /
PassengerPython /home/yourusername/virtualenv/ai_chatbot/3.11/bin/python3.11

# Serve static files directly (bypass Python)
RewriteEngine On
RewriteCond %{REQUEST_URI} ^/static/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route everything else through Passenger
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
